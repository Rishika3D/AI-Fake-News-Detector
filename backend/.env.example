# ── Server ────────────────────────────────────────────────────────────────────
PORT=5050
NODE_ENV=development          # set to "production" on Render/Railway

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — single connection string (Render, Neon, Railway, Supabase all provide this)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B — individual vars (local PostgreSQL)
# DB_USER=ashi
# DB_HOST=localhost
# DB_NAME=verinews
# DB_PASSWORD=yourpassword
# DB_PORT=5432

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── AI / ML ───────────────────────────────────────────────────────────────────
# Get a free token at https://huggingface.co/settings/tokens
# Required in production (replaces the local Flask server)
HF_ACCESS_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL (e.g. https://verinews.vercel.app)
# localhost:5173 is always allowed automatically
FRONTEND_URL=https://your-frontend-domain.com
